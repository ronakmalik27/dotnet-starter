root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{yml,yaml,json,csproj,props,targets,sln}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.cs]
# File-scoped namespaces everywhere (doc 13 section 2); build-enforced.
csharp_style_namespace_declarations = file_scoped
dotnet_diagnostic.IDE0161.severity = error

# var when the type is apparent from the right-hand side (doc 13 section 2).
csharp_style_var_when_type_is_apparent = true
csharp_style_var_for_built_in_types = false
csharp_style_var_elsewhere = false

# CA1716 renames identifiers that collide with Visual Basic keywords, e.g.
# the SharedKernel Error type. The backend is C#-only (ADR-0002) and Error
# is the industry-standard name for the Result error type (ErrorOr,
# FluentResults), so the rule buys nothing here.
dotnet_diagnostic.CA1716.severity = none

# Test names are Method_Scenario_Expectation (doc 13 section 5), so the
# no-underscores rule is off for test code only - standard xUnit practice.
[tests/**/*.cs]
dotnet_diagnostic.CA1707.severity = none

# EF migrations are generated code; the reviewed artifact is the exported
# SQL (doc 07 section 14). Style and quality analyzers stay quiet there.
[**/Migrations/*.cs]
generated_code = true
dotnet_diagnostic.IDE0161.severity = none
