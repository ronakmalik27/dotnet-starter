# Keep the build context small and reproducible: obj/bin are regenerated by
# the in-container restore/publish, so shipping the host's copies only risks
# stale or platform-mismatched artifacts.
**/bin/
**/obj/
**/*.user

# VCS and tooling
.git/
.gitignore
.vs/
.vscode/
.idea/

# Test and coverage output
TestResults/
coverage/
artifacts/

# Docker and docs (not needed inside the image)
Dockerfile
docker-compose.yml
.dockerignore
**/*.md
LICENSE

# Local tooling caches
.venv/
__pycache__/
